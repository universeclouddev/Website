---
import FilePane from '../FilePane.astro';
import { STATS, INTEGRATIONS } from '../../data';
---

<FilePane id="stack" label="stack.txt" dot="var(--color-syn-red)" meta="text" lines={STATS.length + INTEGRATIONS.length}>
	<div class="p-5 sm:p-6">
		<div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
			{
				STATS.map((s) => (
					<div class="rounded-[var(--radius-3)] border border-line-1 bg-surface-inset px-4 py-5 text-center">
						<div class="font-mono font-extrabold tracking-tight leading-none text-accent text-[clamp(28px,3.4vw,38px)]">
							{s.value}
						</div>
						<div class="mt-2 font-mono text-[11px] text-fg-3">{s.label}</div>
					</div>
				))
			}
		</div>

		<div class="mt-6 pt-5 border-t border-line-1">
			<div class="font-mono text-[12px] text-syn-comment italic mb-3"># runs with</div>
			<div class="flex flex-wrap gap-2 font-mono text-[11.5px]">
				{
					INTEGRATIONS.map((name) => (
						<span class="px-2.5 py-1 rounded-[var(--radius-2)] bg-space-2 border border-line-1 text-fg-2">
							{name}
						</span>
					))
				}
			</div>
		</div>
	</div>
</FilePane>
