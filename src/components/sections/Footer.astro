---
import UniverseMark from '../UniverseMark.astro';
import { SOURCE_URL } from '../../data';
---

<footer class="mt-2 border-t border-line-1 pt-8 pb-4 font-mono text-[12px] text-fg-3">
	<div class="flex flex-wrap items-center justify-between gap-5">
		<div class="flex items-center gap-2">
			<UniverseMark size={18} />
			<span class="text-fg-1 font-semibold">universe</span>
			<span class="text-fg-3 hidden sm:inline">· single-binary minecraft orchestrator</span>
		</div>
		<nav class="flex flex-wrap gap-x-6 gap-y-2">
			<a class="hover:text-fg-1 hover:no-underline" href="#readme">docs</a>
			<a class="hover:text-fg-1 hover:no-underline" href={SOURCE_URL} target="_blank" rel="noreferrer">source</a>
			<a class="hover:text-fg-1 hover:no-underline" href="#preview">api reference</a>
			<a class="hover:text-fg-1 hover:no-underline" href="#features">extensions</a>
			<a class="hover:text-fg-1 hover:no-underline" href="#editions">license</a>
		</nav>
	</div>
	<p class="mt-6 syn-comment">
		// © 2026 LunarLabs · Scala Studios — apache-2.0 · numbers are sacred, made in vim
	</p>
</footer>
