---
const CMD = 'java -jar universe-loader.jar';
---

<section class="scroll-mt-12">
	<div
		class="u-reveal rounded-[var(--radius-3)] border bg-space-1 p-7 sm:p-10 text-center shadow-[var(--shadow-panel)]"
		style="border-color:var(--line-accent)"
	>
		<p class="u-label">get started</p>
		<h2
			class="font-mono font-bold tracking-tight mt-3 text-[clamp(21px,3vw,33px)] text-fg-1"
		>
			one binary. <span class="syn-aqua">spin up</span> the whole cluster.
		</h2>
		<p class="mt-3 text-fg-2 max-w-[52ch] mx-auto">
			Download the loader, drop your config, and run it. Node type is a field, not a different install.
		</p>

		<div
			class="mt-7 inline-flex items-center gap-3 bg-surface-inset border border-line-2 rounded-[var(--radius-2)] pl-4 pr-3 py-3 font-mono text-[13px] max-w-full overflow-x-auto"
		>
			<span class="text-tty-prompt shrink-0">❯</span>
			<code class="text-fg-1 whitespace-nowrap">{CMD}</code>
			<button
				type="button"
				data-copy={CMD}
				class="ml-1 shrink-0 px-2 py-0.5 rounded-[var(--radius-2)] text-fg-3 hover:text-accent hover:bg-space-2 transition cursor-pointer"
				aria-label="copy command"
			>copy</button>
		</div>

		<div class="mt-8 flex flex-wrap justify-center gap-3">
			<a
				href="#preview"
				class="inline-flex items-center gap-2 px-5 h-10 rounded-[var(--radius-2)] bg-accent text-accent-ink font-mono text-[13px] font-semibold hover:brightness-110 hover:no-underline transition"
			>read the docs</a>
			<a
				href="https://github.com"
				target="_blank"
				rel="noreferrer"
				class="inline-flex items-center gap-2 px-5 h-10 rounded-[var(--radius-2)] border border-line-2 text-fg-1 font-mono text-[13px] hover:bg-space-2 hover:no-underline transition"
			>view on github</a>
		</div>
	</div>
</section>
