---
import { SOURCE_URL } from '../../data';

const INSTALL = 'curl -fsSL https://get.lunarlabs.dev/universe | sh';
const NOTE = '# installs docker · writes compose.yml · brings the cluster up';
---

<section id="get-started" class="scroll-mt-12">
	<div
		class="u-reveal rounded-[var(--radius-3)] border bg-space-1 p-7 sm:p-10 text-center shadow-[var(--shadow-panel)]"
		style="border-color:var(--line-accent)"
	>
		<p class="u-label">get started</p>
		<h2 class="font-mono font-bold tracking-tight mt-3 text-[clamp(21px,3vw,33px)] text-fg-1">
			one command. <span class="syn-aqua">spin up</span> the whole cluster.
		</h2>
		<p class="mt-3 text-fg-2 max-w-[54ch] mx-auto">
			One line installs Docker, writes a <span class="font-mono text-fg-1">compose.yml</span>, and
			starts the cluster. Prefer standalone? The JAR runs on its own, it just wants more flags.
		</p>

		<div
			class="mt-7 mx-auto w-full max-w-[560px] text-left bg-surface-inset border border-line-2 rounded-[var(--radius-3)] overflow-hidden"
		>
			<div
				class="flex items-center gap-2 px-3 h-8 bg-space-2 border-b border-line-1 font-mono text-[11px] text-fg-3"
			>
				<span>~/universe</span>
				<button
					type="button"
					data-copy={INSTALL}
					class="ml-auto shrink-0 px-2 py-0.5 rounded-[var(--radius-2)] text-fg-3 hover:text-accent hover:bg-space-3 transition cursor-pointer"
					aria-label="copy install command"
				>copy</button>
			</div>
			<div class="px-4 py-3.5 font-mono text-[12.5px] overflow-x-auto">
				<div class="flex items-start gap-2 whitespace-nowrap">
					<span class="text-tty-prompt shrink-0 select-none">❯</span>
					<code class="text-fg-1">{INSTALL}</code>
				</div>
				<div class="syn-comment mt-1.5 pl-[18px] whitespace-nowrap">{NOTE}</div>
			</div>
		</div>

		<div class="mt-8 flex flex-wrap justify-center gap-3">
			<a
				href="#features"
				class="inline-flex items-center gap-2 px-5 h-10 rounded-[var(--radius-2)] bg-accent text-accent-ink font-mono text-[13px] font-semibold hover:brightness-110 hover:no-underline transition"
			>
				<span class="text-accent-ink/60">❯</span> browse features
			</a>
			<a
				href={SOURCE_URL}
				target="_blank"
				rel="noreferrer"
				class="inline-flex items-center gap-2 px-5 h-10 rounded-[var(--radius-2)] border border-line-2 text-fg-1 font-mono text-[13px] hover:bg-space-2 hover:no-underline transition"
			>view the source</a>
		</div>
	</div>
</section>
