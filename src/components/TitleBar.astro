---
import UniverseMark from './UniverseMark.astro';
import { SOURCE_URL } from '../data';
---

<header
	class="flex items-center gap-3 h-[38px] px-3 bg-space-2 border-b border-line-1 select-none"
>
	<span class="flex items-center gap-[7px] pl-0.5">
		<i class="w-3 h-3 rounded-full" style="background:#f7768e"></i>
		<i class="w-3 h-3 rounded-full" style="background:#e0af68"></i>
		<i class="w-3 h-3 rounded-full" style="background:#9ece6a"></i>
	</span>

	<span class="flex items-center gap-2 ml-1.5">
		<UniverseMark size={16} />
		<span class="font-mono text-[13px] font-semibold text-fg-1 tracking-tight">universe</span>
	</span>

	<span class="hidden sm:block mx-auto font-mono text-[11px] text-fg-3">
		na-game-1 · universe-cluster · :7000
	</span>

	<span class="ml-auto sm:ml-0 flex items-center gap-3.5 font-mono text-[11px]">
		<span class="text-syn-green hidden sm:inline">● MASTER</span>
		<a class="text-fg-3 hover:text-fg-1 hover:no-underline" href="/docs">docs</a>
		<a
			class="text-fg-3 hover:text-fg-1 hover:no-underline"
			href={SOURCE_URL}
			target="_blank"
			rel="noreferrer">source</a
		>
	</span>
</header>
