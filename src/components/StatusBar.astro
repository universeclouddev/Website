---
interface Props {
	file?: string;
}
const { file = 'README.md' } = Astro.props;
---

<footer
	class="fixed bottom-0 inset-x-0 z-40 h-[29px] flex items-stretch font-mono text-[11px] bg-space-2 select-none"
>
	<span class="flex items-center px-3 bg-accent text-accent-ink font-bold tracking-wide">NORMAL</span>
	<span class="flex items-center gap-1.5 px-3 bg-space-4 text-fg-1">
		<svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
			<circle cx="6" cy="6" r="2.4" stroke="currentColor" stroke-width="2"></circle>
			<circle cx="6" cy="18" r="2.4" stroke="currentColor" stroke-width="2"></circle>
			<circle cx="18" cy="8" r="2.4" stroke="currentColor" stroke-width="2"></circle>
			<path d="M6 8.4v7.2M8.4 7.2H15a3 3 0 0 1 3 3v.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
		</svg>
		main
	</span>
	<span
		id="sb-file"
		class="flex items-center px-3 bg-space-2 text-fg-3 flex-1 min-w-0 truncate"
	>~/universe/{file}</span>
	<span class="flex items-center px-3 bg-space-2 text-fg-3 sb-opt">utf-8</span>
	<span class="flex items-center px-3 bg-space-2 text-fg-3 sb-opt">unix</span>
	<span id="sb-line" class="flex items-center px-3 bg-space-4 text-fg-1">1:1</span>
	<span id="sb-pct" class="flex items-center px-3 bg-accent text-accent-ink font-semibold">Top</span>
</footer>
