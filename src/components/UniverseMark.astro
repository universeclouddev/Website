---
interface Props {
	size?: number;
	class?: string;
}
const { size = 16, class: className = '' } = Astro.props;
---

<!-- orange planet + light orbit at −24° + aqua moon — the recurring brand geometry -->
<svg
	width={size}
	height={size}
	viewBox="0 0 64 64"
	fill="none"
	class={className}
	aria-hidden="true"
>
	<circle cx="32" cy="32" r="11" fill="var(--color-syn-orange)"></circle>
	<ellipse
		cx="32"
		cy="32"
		rx="26"
		ry="10"
		stroke="var(--color-fg-3)"
		stroke-width="2.5"
		transform="rotate(-24 32 32)"></ellipse>
	<circle cx="53.5" cy="20.5" r="3" fill="var(--color-syn-aqua)"></circle>
</svg>
