---
import Layout from '../layouts/Layout.astro';
import FilePane from '../components/FilePane.astro';
import Endpoint from '../components/api/Endpoint.astro';
import SchemaBlock from '../components/api/SchemaBlock.astro';
import Footer from '../components/sections/Footer.astro';
import { SOURCE_URL } from '../data';
import { API_INFO, API_GROUPS, API_SCHEMAS, API_NAV, API_STATS } from '../api/spec';
---

<Layout
	title="Universe API: REST + WebSocket reference"
	description="Reference for the Universe orchestrator API: bearer-authenticated REST endpoints and WebSocket streams to deploy, control and observe instances across the cluster."
	navItems={API_NAV}
	statusFile="api/README.md"
>
	<FilePane id="overview" label="README.md" file="api/README.md" dot="var(--color-syn-blue)" meta="rest + websocket reference" lines={API_STATS.endpoints}>
		<div class="p-5 sm:p-8">
			<p class="u-label mb-4">orchestrator control plane</p>
			<h1 class="font-mono font-extrabold tracking-tight leading-[1.1] text-[clamp(26px,3.6vw,40px)] text-fg-1">
				drive the whole <span class="syn-green">cluster</span> over HTTP<span class="text-accent">.</span>
			</h1>
			<p class="mt-4 max-w-[64ch] text-fg-2 leading-relaxed">
				Every console action is an endpoint. Deploy instances, stream live logs, edit templates and
				dispatch commands across nodes, authenticated with a single bearer token, served by the
				master on <span class="syn-yellow">:7000</span>.
			</p>

			<div class="mt-6 flex flex-wrap gap-2.5 font-mono text-[11px]">
				<span class="px-2 py-1 rounded-[var(--radius-2)] bg-space-2 border border-line-1 text-fg-2">openapi {API_INFO.openapi}</span>
				<span class="px-2 py-1 rounded-[var(--radius-2)] bg-space-2 border border-line-1 text-fg-2">bearer auth</span>
				<span class="px-2 py-1 rounded-[var(--radius-2)] bg-space-2 border border-line-1 text-syn-yellow">:7000</span>
				<span class="px-2 py-1 rounded-[var(--radius-2)] bg-space-2 border border-line-1 text-syn-green">v{API_INFO.version}</span>
			</div>

			<div class="mt-5 max-w-[560px] rounded-[var(--radius-2)] border border-line-2 bg-surface-inset overflow-hidden">
				<div class="flex items-center gap-2 px-3 h-8 bg-space-2 border-b border-line-1 font-mono text-[11px] text-fg-3">
					<span>base url</span>
					<button
						type="button"
						data-copy={API_INFO.baseUrl}
						class="ml-auto shrink-0 px-2 py-0.5 rounded-[var(--radius-2)] text-fg-3 hover:text-accent hover:bg-space-3 transition cursor-pointer"
						aria-label="copy base url"
					>copy</button>
				</div>
				<div class="px-4 py-2.5 font-mono text-[12.5px] text-fg-1 overflow-x-auto">{API_INFO.baseUrl}</div>
			</div>

			<a
				href="/openapi.json"
				download="universe-openapi.json"
				class="mt-3 inline-flex items-center gap-2 font-mono text-[12px] text-fg-3 hover:text-accent hover:no-underline transition"
			>
				<svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M12 4v10m0 0 3.5-3.5M12 14l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					<path d="M5 19h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
				</svg>
				download openapi.json
				<span class="text-fg-3/60">· {API_INFO.openapi}</span>
			</a>

			<div class="mt-6 grid sm:grid-cols-2 gap-4">
				<div class="flex flex-col rounded-[var(--radius-3)] border border-line-1 overflow-hidden">
					<div class="u-pane-title text-[11px]">
						<span class="w-2 h-2 rounded-full" style="background:var(--color-syn-aqua)"></span>
						authentication
					</div>
					<div class="flex-1 p-4 font-mono text-[12px] leading-[1.7] bg-surface-inset">
						<div class="text-syn-comment italic"># send your key on every request</div>
						<div class="mt-1"><span class="text-fg-3">Authorization:</span> <span class="text-fg-1">Bearer</span> <span class="syn-green">$KEY</span></div>
						<div class="mt-3 text-syn-comment italic"># mint one from the master console</div>
						<div class="mt-1"><span class="text-tty-prompt">›</span> <span class="text-fg-1">key create</span> <span class="syn-yellow">--scope</span> <span class="syn-green">ALL</span></div>
						<div class="mt-3 text-fg-3 leading-relaxed">WebSocket handshakes carry the same bearer header.</div>
					</div>
				</div>

				<div class="flex flex-col rounded-[var(--radius-3)] border border-line-1 overflow-hidden">
					<div class="u-pane-title text-[11px]">
						<span class="w-2 h-2 rounded-full" style="background:var(--color-syn-orange)"></span>
						permissions & limits
					</div>
					<div class="flex-1 p-4 font-mono text-[12px] leading-[1.8] bg-surface-inset">
						<div><span class="syn-green">ALL</span> <span class="text-fg-3">· full access · bypasses rate limits</span></div>
						<div><span class="syn-aqua">PUBLIC</span> <span class="text-fg-3">· public reads only · no instance ops</span></div>
						<div class="mt-2 text-fg-3 leading-relaxed">
							Public keys are capped at <span class="text-fg-1">100</span> calls / <span class="text-fg-1">60s</span>;
							admin keys are unmetered.
						</div>
					</div>
				</div>
			</div>
		</div>
	</FilePane>

	{
		API_GROUPS.map((g) => (
			<FilePane
				id={g.id}
				label={g.label}
				file={`api/${g.label}`}
				dot={g.dot}
				meta={g.blurb}
				lines={g.endpoints.length}
			>
				<ul>
					{g.endpoints.map((e) => (
						<Endpoint endpoint={e} />
					))}
				</ul>
			</FilePane>
		))
	}

	<FilePane id="schemas" label="schemas.ts" file="api/schemas.ts" dot="var(--color-syn-red)" meta="request & response models" lines={API_SCHEMAS.length}>
		<div class="p-5 sm:p-6">
			<p class="text-fg-2 mb-5 max-w-[70ch]">
				The shapes referenced by every endpoint. <span class="syn-aqua">Aqua</span> types are links.
				Click to jump to their definition.
			</p>
			<div class="grid lg:grid-cols-2 gap-4 items-start">
				{API_SCHEMAS.map((s) => <SchemaBlock schema={s} />)}
			</div>
		</div>
	</FilePane>

	<div class="flex flex-wrap items-center gap-3">
		<a
			href="/"
			class="inline-flex items-center gap-2 px-4 h-10 rounded-[var(--radius-2)] border border-line-2 text-fg-1 font-mono text-[13px] hover:bg-space-2 hover:no-underline transition"
		>
			<span class="text-fg-3">←</span> back to readme
		</a>
		<a
			href={SOURCE_URL}
			target="_blank"
			rel="noreferrer"
			class="inline-flex items-center gap-2 px-4 h-10 rounded-[var(--radius-2)] bg-accent text-accent-ink font-mono text-[13px] font-semibold hover:brightness-110 hover:no-underline transition"
		>
			<span class="text-accent-ink/70">❯</span> view the source
		</a>
	</div>

	<Footer />
</Layout>
