---
import { getCollection, render } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';
import Callout from '../../components/docs/Callout.astro';
import CodeBlock from '../../components/docs/CodeBlock.astro';
import CardGrid from '../../components/docs/CardGrid.astro';
import Card from '../../components/docs/Card.astro';
import Steps from '../../components/docs/Steps.astro';
import Step from '../../components/docs/Step.astro';
import Tabs from '../../components/docs/Tabs.astro';
import Accordion from '../../components/docs/Accordion.astro';
import Mermaid from '../../components/docs/Mermaid.astro';
import { hrefFor } from '../../docs/nav';

export async function getStaticPaths() {
	const entries = await getCollection('docs');
	return entries.map((entry) => ({
		params: { slug: entry.id === 'introduction' ? undefined : entry.id },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const components = { Callout, CodeBlock, CardGrid, Card, Steps, Step, Tabs, Accordion, Mermaid };
---

<DocLayout
	slug={hrefFor(entry.id)}
	title={entry.data.title}
	lead={entry.data.lead}
	description={entry.data.description}
	filePath={`${entry.id}.md`}
>
	<Content components={components} />
</DocLayout>
